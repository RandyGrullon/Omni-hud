# Supabase (auth and profiles)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Groq (chat + optional Whisper for voice)
GROQ_API_KEY=your-groq-api-key

# Optional: base URL of omni-web API for syncing Groq key to web (e.g. https://your-app.vercel.app)
OMNI_WEB_API_URL=https://localhost:3000
